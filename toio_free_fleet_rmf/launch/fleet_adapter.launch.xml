<?xml version="1.0"?>
<launch>
  <arg name="use_sim_time" default="false"
       description="Use the /clock topic for time to sync with simulation"/>
  <arg name="server_uri" default=""
       description="URI of the API server (rmf-web). Empty disables uploads."/>

  <arg name="config_file"
       default="$(find-pkg-share toio_free_fleet_rmf)/config/fleet/toio_config.yaml"/>
  <arg name="nav_graph_file"
       default="$(find-pkg-share toio_free_fleet_rmf)/maps/toio_map/nav_graphs/0.yaml"
       description="Built automatically by toio_free_fleet_rmf's CMakeLists at install time."/>

  <include file="$(find-pkg-share toio_free_fleet_rmf)/launch/include/common.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
  </include>

  <include file="$(find-pkg-share free_fleet_adapter)/fleet_adapter.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="config_file" value="$(var config_file)"/>
    <arg name="nav_graph_file" value="$(var nav_graph_file)"/>
    <arg name="server_uri" value="$(var server_uri)"/>
  </include>
</launch>
