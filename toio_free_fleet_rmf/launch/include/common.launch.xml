<?xml version="1.0"?>
<launch>
  <arg name="use_sim_time" default="false"/>

  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_schedule" name="rmf_traffic_schedule_primary" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_blockade" name="rmf_traffic_blockade_node" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_fleet_adapter" exec="dispatcher_node" name="dispatcher_node" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <node pkg="rmf_task_ros2" exec="rmf_task_dispatcher" name="rmf_task_dispatcher" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>
</launch>
