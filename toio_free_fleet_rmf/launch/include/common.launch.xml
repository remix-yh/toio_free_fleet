<?xml version="1.0"?>
<!--
Minimum RMF backend for the toio fleet. Modelled after rmf_demos' common.launch.xml
but trimmed to the nodes the toio adapter actually needs (no door/lift/visualization).
-->
<launch>
  <arg name="use_sim_time" default="false"
       description="Use the /clock topic for time to sync with simulation"/>
  <arg name="building_map_file"
       default="$(find-pkg-share toio_free_fleet_rmf)/maps/toio_map/toio_map.building.yaml"
       description="Building description yaml for rmf_building_map_tools"/>
  <arg name="bidding_time_window" default="2.0"/>
  <arg name="use_unique_hex_string_with_task_id" default="true"/>
  <arg name="server_uri" default=""/>
  <arg name="headless" default="false"
       description="Set true to skip rviz2 (the RMF schedule visualization)"/>
  <!-- Our own rviz config. The stock rmf.rviz subscribes the Map display to
       /floor_plan, but rmf's floorplan_visualizer publishes to /floorplan, so
       the mat image never shows. toio.rviz fixes that topic (and bumps the Map
       alpha so the mostly-white mat is visible). -->
  <arg name="viz_config_file"
       default="$(find-pkg-share toio_free_fleet_rmf)/config/rviz/toio.rviz"/>

  <!-- Traffic Schedule -->
  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_schedule" name="rmf_traffic_schedule_primary" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- Blockade Moderator -->
  <node pkg="rmf_traffic_ros2" exec="rmf_traffic_blockade" output="both">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- Building Map Server (adapter needs to query the building/level info) -->
  <node pkg="rmf_building_map_tools" exec="building_map_server" args="$(var building_map_file)">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- Mutex Group Supervisor -->
  <node pkg="rmf_fleet_adapter" exec="mutex_group_supervisor">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
  </node>

  <!-- Task Dispatcher (accepts dispatch_patrol etc.) -->
  <node pkg="rmf_task_ros2" exec="rmf_task_dispatcher" output="screen">
    <param name="use_sim_time" value="$(var use_sim_time)"/>
    <param name="bidding_time_window" value="$(var bidding_time_window)"/>
    <param name="use_unique_hex_string_with_task_id" value="$(var use_unique_hex_string_with_task_id)"/>
    <param name="server_uri" value="$(var server_uri)"/>
  </node>

  <!-- Visualization. The schedule_visualizer_node serves trajectory data on
       ws://localhost:8006, which the rmf-web dashboard reads to render the
       path lines for in-flight tasks. headless=false brings up rviz2 too. -->
  <include file="$(find-pkg-share rmf_visualization)/visualization.launch.xml">
    <arg name="use_sim_time" value="$(var use_sim_time)"/>
    <arg name="map_name" value="L1"/>
    <arg name="headless" value="$(var headless)"/>
    <arg name="viz_config_file" value="$(var viz_config_file)"/>
  </include>

  <!-- Reservation queue manager: deconflicts is_parking_spot waypoints when
       multiple robots want the same parking. Activated per-fleet by setting
       `use_parking_reservations: True` in the fleet config yaml. -->
  <arg name="use_reservation_node" default="true"
       description="Run the parking-reservation queue_manager"/>
  <group if="$(var use_reservation_node)">
    <node pkg="rmf_reservation_node" exec="queue_manager">
      <param name="use_sim_time" value="$(var use_sim_time)"/>
    </node>
  </group>
</launch>
